    font-size: 12px; font-weight: 700; padding: 8px 14px;
    border-radius: 999px; text-decoration: none; white-space: nowrap;
  }
  #cta-toast-close {
    flex-shrink: 0; color: #667085; background: none; border: none;
    cursor: pointer; padding: 4px; display: flex; align-items: center;
  }
  #cta-toast-close:hover { color: white; }
</style>

<script>
  /* ── TOC 자동 생성 ── */
  const content = document.querySelector('.content');
  const tocDesktop = document.getElementById('toc-desktop');
  const tocMobilePanel = document.getElementById('toc-mobile-panel');

  if (content && (tocDesktop || tocMobilePanel)) {
    const headings = [...content.querySelectorAll('h2, h3')];

    headings.forEach((el, i) => {
      if (!el.id) {
        el.id = 'heading-' + i;
      }
    });

    const makeLink = (el: Element) => {
      const a = document.createElement('a');
      a.href = '#' + el.id;
      a.textContent = el.textContent ?? '';
      if (el.tagName === 'H3') a.classList.add('toc-h3');
      return a;
    };

    headings.forEach((el) => {
      tocDesktop?.appendChild(makeLink(el));
      tocMobilePanel?.appendChild(makeLink(el));
    });

    /* 스크롤 활성 표시 */
    if (tocDesktop && headings.length) {
      const links = [...tocDesktop.querySelectorAll('a')];
      const setActive = (id: string) =>
        links.forEach((a) => a.classList.toggle('active', a.getAttribute('href') === '#' + id));

      headings.forEach((el) => {
        new IntersectionObserver(
          (entries) => {
            entries.filter((e) => e.isIntersecting).forEach((e) => setActive(e.target.id));
          },
          { rootMargin: '-64px 0px -60% 0px', threshold: 0 }
        ).observe(el);
      });
    }
  }

  /* ── 모바일 TOC 토글 ── */
  const toggle = document.getElementById('toc-mobile-toggle');
  const panel = document.getElementById('toc-mobile-panel');
  toggle?.addEventListener('click', () => {
    const open = panel!.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });
  panel?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      panel.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  /* ── 플로팅 토스트: 본문 50% 스크롤 시 등장 ── */
  const toast = document.getElementById('cta-toast');
  const closeBtn = document.getElementById('cta-toast-close');
  const article = document.querySelector('.content');
  if (toast && article && !sessionStorage.getItem('cta-dismissed')) {
    const show = () => { toast.style.transform = 'translateY(0)'; };
    const onScroll = () => {
      const { top, height } = article.getBoundingClientRect();
      if (-top / height >= 0.5) { show(); window.removeEventListener('scroll', onScroll); }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    closeBtn?.addEventListener('click', () => {
      toast.style.transform = 'translateY(120%)';
      sessionStorage.setItem('cta-dismissed', '1');
    });
  }
</script>
