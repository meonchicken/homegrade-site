---
import Base from '../layouts/Base.astro';

const siteUrl = Astro.site?.href ?? 'https://homegrade.kr/';
const aboutUrl = new URL('/about/', siteUrl).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${aboutUrl}#person`,
  name: '김재형',
  jobTitle: 'HomeGrade 편집장',
  email: 'mailto:zamzaricompany@gmail.com',
  url: aboutUrl,
  description: '종합 브랜드사 BM(Brand Manager)·마케팅 4년 차. 바이럴·퍼포먼스·콘텐츠·세일즈 전 채널을 통합 운영했으며, 재직 시 주방·욕실·청소·생활소모품 등 홈리빙 카테고리를 다뤘다.',
  knowsAbout: ['홈리빙 용품', '소재·안전 인증', 'KC·식약처·BPA-Free', '쿠팡 파트너스', '리뷰 데이터 분석', '브랜드 마케팅'],
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'certification',
    name: 'SQLD (SQL Developer)',
  },
  worksFor: { '@type': 'Organization', name: 'HomeGrade', url: siteUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '소개', item: aboutUrl },
  ],
};

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': aboutUrl,
  url: aboutUrl,
  name: 'HomeGrade 소개 - 데이터 기반 홈리빙 용품 평가',
  inLanguage: 'ko-KR',
  mainEntity: { '@id': `${aboutUrl}#person` },
};

const schemas = [personSchema, breadcrumbSchema, aboutSchema];
---

<Base
  title="HomeGrade 소개 - 데이터 기반 홈리빙 용품 평가"
  description="HomeGrade는 쿠팡 리뷰 빅데이터와 KC·식약처·BPA-Free 인증으로 홈리빙 용품을 등급 비교하는 사이트입니다. 운영자·평가 기준·검수 프로세스를 공개합니다."
  ogType="website"
  schemas={schemas}
>
  <article class="page">
    <h1>HomeGrade 소개</h1>

    <h2>왜 만들었나요?</h2>
    <p>홈리빙 시장은 광고와 협찬이 압도적입니다. 텀블러·수세미·세제·휴지 같은 일상 소모품을 고를 때 "어떤 게 진짜 좋은가"를 객관적으로 비교할 방법이 부족합니다. HomeGrade는 쿠팡 인증 구매자 리뷰·네이버 블로그 후기·디시인사이드 토론을 자체 분석 시스템으로 종합하고, KC·식약처·BPA-Free 같은 <strong>공식 안전 인증</strong>을 별도로 검증해 <strong>객관적인 등급</strong>을 매깁니다.</p>

    <h2>운영자 (Editor)</h2>
    <div class="person-card">
      <p><strong>김재형</strong> · HomeGrade 편집장</p>
      <ul>
        <li><strong>경력</strong>: 종합 브랜드사 BM(Brand Manager) · 마케팅 4년 차 — <strong>바이럴 · 퍼포먼스 · 콘텐츠 · 세일즈</strong> 전 채널 통합 운영</li>
        <li><strong>카테고리 경험</strong>: 재직 중 다수 카테고리를 다뤘으며, 그중 <strong>주방·욕실·청소·생활소모품</strong> 등 홈리빙 SKU의 브랜드 운영·신제품 런칭·리뷰 캠페인을 직접 담당</li>
        <li><strong>자격</strong>: SQLD — 본 사이트의 상품 데이터·가격 비교·리뷰 정량 분석은 SQL 기반으로 직접 검증</li>
        <li><strong>연락처</strong>: <a href="mailto:zamzaricompany@gmail.com">zamzaricompany@gmail.com</a></li>
      </ul>
      <p class="note">※ 본 사이트의 모든 글은 운영자가 직접 기획·검수합니다. 광고비와 추천 결정은 분리되어 있으며, 본문에 "직접 사용 후기"는 사용하지 않고 리뷰 빅데이터·1차 출처를 기반으로 작성합니다.</p>
    </div>

    <h2>출처·인증 검증 프로세스</h2>
    <div class="person-card">
      <p>홈리빙 제품의 안전·성분·인증 관련 주장은 다음 1차 자료만 사용합니다.</p>
      <ul>
        <li><strong>식약처</strong> 식품용 기구 등록 정보 (texa.foodsafetykorea.go.kr)</li>
        <li><strong>국가기술표준원 KC·KS 인증</strong> 데이터베이스 (safetykorea.kr)</li>
        <li><strong>한국소비자원</strong> 안전성 조사·비교 평가 리포트</li>
        <li>제조사가 공식 발행한 시험성적서·재질 인증서 (BPA-Free·프탈레이트-Free 등)</li>
        <li>ISO·EN 등 국제 표준 규격 (보온 ISO 8442-2, 스테인리스 STS 등)</li>
      </ul>
      <p class="note">※ 인증 번호·발급 기관·시험 자료가 공개되지 않은 주장은 "검증 불가"로 표기하고, 추천 등급에 반영하지 않습니다.</p>
    </div>

    <h2>평가 5축 (각 5점 만점)</h2>
    <table>
      <thead><tr><th>항목</th><th>가중치</th><th>측정 방식</th></tr></thead>
      <tbody>
        <tr><td>핵심 성능</td><td>30%</td><td>카테고리별 정의 (보온·세척력·흡수력·내열 등)</td></tr>
        <tr><td>내구성·수명</td><td>20%</td><td>사용 기간 대비 만족도 추이</td></tr>
        <tr><td>세척 편의</td><td>15%</td><td>식기세척기 호환·분해 용이성·잔여물</td></tr>
        <tr><td>가성비</td><td>20%</td><td>가격 대비 성능 환산 (1일 비용·g·ml 당 단가 등)</td></tr>
        <tr><td>디자인·만족도</td><td>15%</td><td>사용자 디자인 평가·시각적 완성도</td></tr>
      </tbody>
    </table>

    <h2>분석 방법론 — 한 편의 글이 발행되기까지</h2>
    <p>추상적인 "리뷰 종합"이 아니라 실제로 어떤 절차로 등급을 매기는지 공개합니다. "<a href="/tumbler-top5-2026/">텀블러 추천 TOP 5</a>" 글을 예로 들어 단계별 작업을 설명합니다.</p>

    <div class="person-card">
      <p><strong>1단계 · 키워드·SKU 풀 추출</strong></p>
      <p>네이버 검색광고 API + DataForSEO Google KR 데이터를 SQL로 결합해 월 검색량 1,000회 이상의 LSI 키워드를 추출합니다. "텀블러 추천"의 경우 보온·차량용·핸들형·1.2L 등 9개 sub-intent를 정리한 뒤 후보 SKU 80여 개를 선정했습니다.</p>

      <p><strong>2단계 · 리뷰 빅데이터 수집·정량 분석</strong></p>
      <p>쿠팡 인증 구매자 리뷰·네이버 블로그·디시인사이드·여성시대 등 한국 커뮤니티 게시물을 자동 수집해 PostgreSQL로 적재합니다. 텀블러 글의 경우 후보 SKU별 평균 287건의 리뷰가 수집됐고, "보온 시간", "누수", "세척", "컵홀더 호환" 같은 핵심 키워드의 빈도·감성을 정량화해 점수에 반영했습니다.</p>

      <p><strong>3단계 · 공식 인증·표준 검증</strong></p>
      <p>주장 가능한 모든 인증 번호와 표준 규격을 1차 자료에서 확인합니다. 텀블러 글에서는 ISO 8442-2 보온 기준(95℃ 물 → 6시간 후 70℃ 유지), BPA-Free 시험성적서, 스테인리스 18/8 등급, 식약처 식품용 기구 등록 여부 4가지를 SKU별로 교차 검증했습니다.</p>

      <p><strong>4단계 · 가성비 계산</strong></p>
      <p>단순 가격 비교가 아닌 "용량 대비 단가(원/ml)", "1일 사용 환산 비용" 같은 정규화 지표를 계산합니다. SQL 한 줄로 80개 SKU 전체를 비교한 뒤 평가 5축에 가중치를 적용해 최종 순위를 산출합니다.</p>

      <p><strong>5단계 · 작성·검수·정정</strong></p>
      <p>편집장이 본문을 직접 작성하고, 발행 전 인증 번호·발급 기관·시험 자료 링크가 모두 1차 출처와 일치하는지 재확인합니다. 발행 이후에도 가격은 주 1회, 등급은 월 1회 갱신하며, 사실 오류 제보 시 24시간 내에 정정 이력을 글 하단에 공개합니다.</p>
    </div>

    <h2>편집 원칙 &amp; 검수 프로세스</h2>
    <ul>
      <li><strong>광고와 콘텐츠 분리</strong>: 협찬 글은 명시적으로 표기하며, 본 사이트의 등급·순위는 어떠한 광고비와도 연동되지 않습니다.</li>
      <li><strong>데이터 우선</strong>: 모든 주장에 수치·출처를 표기합니다. "리뷰 종합" 같은 표현은 실제 인용 가능한 게시물·인증 데이터로 정리합니다.</li>
      <li><strong>약점도 솔직하게</strong>: 단점이 없는 제품은 추천하지 않습니다.</li>
      <li><strong>인증 우선</strong>: KC·KS·식약처·BPA-Free 등 공식 인증이 확인되지 않은 제품은 1순위로 추천하지 않습니다.</li>
      <li><strong>업데이트 주기</strong>: 가격은 주 1회, 등급은 월 1회, 인증·표준 정보는 발급 기관 개정 시마다 갱신합니다.</li>
      <li><strong>직접 사용 표현 금지</strong>: 모든 평가는 리뷰 데이터 분석·인증 검증 기반이며, "제가 써본 결과" 같은 표현은 사용하지 않습니다.</li>
      <li><strong>오류 정정</strong>: 사실 오류 제보 시 24시간 내 검토 → 정정 시 글 하단에 변경 이력을 공개합니다.</li>
    </ul>

    <h2>시리즈 사이트</h2>
    <ul>
      <li>🐾 반려동물: <a href="https://doggrade.com/" rel="noopener">doggrade.com</a></li>
      <li>👶 육아·영유아: <a href="https://babygrade.kr/" rel="noopener">babygrade.kr</a></li>
    </ul>

    <h2>제휴 고지 (광고 고지)</h2>
    <p>본 사이트는 쿠팡 파트너스 활동의 일환으로 본문 내 링크를 통해 발생한 매출에 따라 일정액의 수수료를 제공받습니다. 단, <strong>수수료와 무관하게 데이터·인증에 기반한 추천만</strong> 작성합니다.</p>

    <h2>문의 &amp; 정정 요청</h2>
    <ul>
      <li>제품 추가·오류 제보: <a href="mailto:zamzaricompany@gmail.com">zamzaricompany@gmail.com</a></li>
      <li>인증·표준 사실관계 정정: 위 이메일로 출처와 함께 보내주시면 24시간 내 검토합니다.</li>
    </ul>
  </article>
</Base>

<style>
  .page { max-width: 760px; margin: 30px auto; padding: 0 24px; }
  .page h1 { font-size: 2rem; margin-bottom: 24px; }
  .page h2 { font-size: 1.3rem; margin: 32px 0 12px; padding-bottom: 6px; border-bottom: 2px solid var(--border); }
  .page p { margin-bottom: 14px; }
  .page ul { margin: 0 0 14px 22px; }
  .page li { margin: 6px 0; }
  .page table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: .92rem; }
  .page th, .page td { padding: 10px; border: 1px solid var(--border); text-align: left; }
  .page th { background: #fff5e6; }
  .person-card {
    background: #fafafa;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    margin: 12px 0 18px;
  }
  .person-card ul { margin: 8px 0 8px 18px; }
  .person-card .note { font-size: .85rem; color: var(--muted); margin: 8px 0 0; line-height: 1.6; }
</style>
