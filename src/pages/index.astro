---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { proxyImage } from '../utils/image-proxy';
import { catUrl } from '../utils/categories';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const categories = ['주방', '욕실', '청소', '소모품', '가전'] as const;
const byCategory = Object.fromEntries(categories.map((c) => [c, posts.filter((p) => p.data.category === c).slice(0, 4)]));

const siteUrl = Astro.site!.href;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'HomeGrade',
  alternateName: '홈그레이드',
  url: siteUrl,
  inLanguage: 'ko-KR',
  description: '주방·욕실·청소·생활소모품·가전 등급 비교. 쿠팡 리뷰·맘카페·디시 후기 종합과 안전 인증 검증으로 진짜 좋은 제품만 골라드려요.',
  publisher: { '@type': 'Organization', name: 'HomeGrade' },
};

const aboutUrl = new URL('/about/', Astro.site).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${aboutUrl}#person`,
  name: '김재형',
  jobTitle: 'HomeGrade 편집장',
  email: 'mailto:zamzaricompany@gmail.com',
  url: aboutUrl,
  description: '종합 브랜드사 BM(Brand Manager)·마케팅 4년 차. 바이럴·퍼포먼스·콘텐츠·세일즈 전 채널을 통합 운영했으며, 재직 시 주방·욕실·청소·생활소모품 등 홈리빙 카테고리를 다뤘다.',
  knowsAbout: ['홈리빙 용품', '소재·안전 인증', 'KC·식약처·BPA-Free', '리뷰 데이터 분석', '브랜드 마케팅'],
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'certification',
    name: 'SQLD (SQL Developer)',
  },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}#organization`,
  name: 'HomeGrade',
  url: siteUrl,
  logo: new URL('/og-default.png', Astro.site).href,
  founder: { '@id': `${aboutUrl}#person` },
  employee: { '@id': `${aboutUrl}#person` },
  sameAs: ['https://doggrade.com/', 'https://babygrade.kr/'],
};

const schemas = [websiteSchema, organizationSchema, personSchema];
---

<Base
  title="HomeGrade - 주방·욕실·청소·소모품·가전 등급 비교 사이트 (2026 리뷰 빅데이터)"
  description="주방·욕실·청소·생활소모품·가전 등급 비교. 쿠팡 리뷰·맘카페·디시 후기 종합과 안전 인증 검증으로 진짜 좋은 제품만 골라드려요."
  ogType="website"
  schemas={schemas}
>
  <section class="hero-banner">
    <div class="hero-inner">
      <h1>홈리빙 용품, <br />데이터로 등급 비교하세요</h1>
      <p>주방·욕실·청소·소모품·가전 - 리뷰 빅데이터 분석</p>
    </div>
  </section>

  {posts.length === 0 && (
    <section class="empty">
      <p>아직 게시된 글이 없어요. 곧 첫 리뷰가 올라옵니다 🏠</p>
    </section>
  )}

  {categories.map((cat) => byCategory[cat].length > 0 && (
    <section class="cat-section">
      <div class="section-header">
        <h2>{cat}</h2>
        <a href={catUrl(cat)} class="more">전체 보기 →</a>
      </div>
      <div class="post-grid">
        {byCategory[cat].map((post) => (
          <a class="post-card" href={`/${post.id}`}>
            <img src={proxyImage(post.data.heroImage)} alt={post.data.heroImageAlt} loading="lazy" width="400" height="225" />
            <div class="post-body">
              <span class="cat-tag">{post.data.category}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <!-- ── 전체 글 목록 (모든 글을 홈에서 1클릭으로 — 크롤 깊이·내부링크 보강) ── -->
  {posts.length > 0 && (
    <section class="archive" aria-labelledby="archive-heading">
      <div class="section-header">
        <h2 id="archive-heading">전체 글</h2>
        <span class="archive-count">{posts.length}개</span>
      </div>
      {categories.map((cat) => {
        const inCat = posts.filter((p) => p.data.category === cat);
        return inCat.length > 0 && (
          <div class="archive-group">
            <h3 class="archive-cat">
              <a href={catUrl(cat)}>{cat}</a><span>{inCat.length}</span>
            </h3>
            <ul class="archive-list">
              {inCat.map((p) => (
                <li><a href={`/${p.id}`}>{p.data.title}</a></li>
              ))}
            </ul>
          </div>
        );
      })}
    </section>
  )}

  <!-- ── 편집장 소개 (E-E-A-T) ── -->
  <section class="editor-section" aria-labelledby="editor-heading">
    <div class="editor-card">
      <p class="editor-label">편집장이 직접 분석합니다</p>
      <h2 id="editor-heading" class="editor-name"><strong>김재형</strong> · HomeGrade 편집장</h2>
      <p class="editor-bio">
        <strong>종합 브랜드사 BM(Brand Manager)·마케팅 4년 차.</strong>
        바이럴·퍼포먼스·콘텐츠·세일즈 전 채널을 통합 운영했으며,
        재직 중 주방·욕실·청소·생활소모품 등 홈리빙 카테고리의 브랜드 운영·신제품 런칭·리뷰 캠페인을 직접 담당했습니다.
      </p>
      <p class="editor-bio">
        <strong>SQLD 보유</strong> — 본 사이트의 쿠팡 리뷰·가격·카테고리 데이터는 SQL 기반으로 직접 추출·검증합니다.
        모든 등급은 광고비와 분리되어 있으며, 본문에 "직접 사용 후기"는 사용하지 않고 리뷰 빅데이터·공식 인증·1차 출처를 기반으로 작성합니다.
      </p>
      <a href="/about/" class="editor-link" rel="author">평가 기준·검수 프로세스·외부 자문 보기 →</a>
    </div>
  </section>
</Base>

<style is:global>
  .editor-section {
    max-width: 760px;
    margin: 48px auto 32px;
    padding: 0 24px;
  }
  .editor-card {
    background: #fafafa;
    border: 1px solid var(--border);
    border-left: 4px solid var(--primary);
    border-radius: 8px;
    padding: 22px 24px;
  }
  .editor-label {
    font-size: .75rem;
    font-weight: 700;
    color: var(--primary-dark);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 6px;
  }
  .editor-name {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--text);
    border: none !important;
    padding: 0 !important;
  }
  .editor-bio {
    font-size: .92rem;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 10px;
    word-break: keep-all;
    overflow-wrap: break-word;
  }
  .editor-link {
    display: inline-block;
    margin-top: 6px;
    font-size: .88rem;
    font-weight: 600;
    color: var(--primary-dark);
    text-decoration: none;
    border-bottom: 1px solid var(--primary);
    padding-bottom: 1px;
  }
  .editor-link:hover { color: var(--primary); }
  @media (max-width: 600px) {
    .editor-section { padding: 0 16px; margin: 32px auto 24px; }
    .editor-card { padding: 18px 18px; }
    .editor-name { font-size: 1.05rem; }
    .editor-bio { font-size: .88rem; }
  }
</style>

<style>
  .hero-banner {
    background: linear-gradient(135deg, #ffefd5 0%, #fff5e6 100%);
    padding: 60px 24px;
    text-align: center;
  }
  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-banner h1 {
    font-size: 2.2rem;
    line-height: 1.3;
    margin-bottom: 14px;
    color: var(--text);
  }
  .hero-banner p {
    color: var(--muted);
    font-size: 1.05rem;
  }
  .empty {
    max-width: 1100px;
    margin: 60px auto;
    padding: 60px 24px;
    text-align: center;
    background: #fff;
    border-radius: 8px;
    color: var(--muted);
  }
  .cat-section {
    max-width: 1100px;
    margin: 50px auto;
    padding: 0 24px;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 18px;
  }
  .section-header h2 {
    font-size: 1.5rem;
  }
  .more {
    font-size: .9rem;
    color: var(--muted);
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 18px;
  }
  .post-card {
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,.05);
    color: inherit;
    text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(0,0,0,.08);
    text-decoration: none;
  }
  .post-card img {
    aspect-ratio: 16/9;
    object-fit: cover;
    background: #faf5ee;
  }
  .post-body {
    padding: 14px 16px 18px;
  }
  .cat-tag {
    display: inline-block;
    background: #fff5e6;
    color: var(--primary-dark);
    font-size: .72rem;
    padding: 2px 8px;
    border-radius: 12px;
    margin-bottom: 8px;
    font-weight: 600;
  }
  .post-body h3 {
    font-size: 1rem;
    line-height: 1.4;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-body p {
    color: var(--muted);
    font-size: .85rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 600px) {
    .hero-banner h1 { font-size: 1.6rem; }
  }

  /* ── 전체 글 아카이브 ── */
  .archive {
    max-width: 1100px;
    margin: 50px auto;
    padding: 0 24px;
  }
  .archive-count { font-size: .85rem; color: var(--muted); font-weight: 600; }
  .archive-group { margin-bottom: 22px; }
  .archive-cat {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .archive-cat a { color: var(--primary-dark); text-decoration: none; }
  .archive-cat a:hover { text-decoration: underline; }
  .archive-cat span { font-size: .78rem; color: var(--muted); font-weight: 500; }
  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px 18px;
  }
  .archive-list li { margin: 0; }
  .archive-list a {
    display: block;
    padding: 5px 0 5px 14px;
    font-size: .9rem;
    line-height: 1.5;
    color: var(--text);
    text-decoration: none;
    position: relative;
    border-radius: 4px;
  }
  .archive-list a::before { content: '·'; position: absolute; left: 4px; color: var(--primary); }
  .archive-list a:hover { color: var(--primary-dark); text-decoration: underline; }
  @media (max-width: 600px) {
    .archive { padding: 0 16px; margin: 36px auto; }
    .archive-list { grid-template-columns: 1fr; }
  }
</style>
